/**
 * FreeDress 畅搭 · Editorial Couture Design System
 * Global Styles — Postal Monochromatic · Neo-minimalism
 */

/* === CSS Variables (Design Tokens) === */
page {
  /* Atelier Palette */
  --ink: #1F1B16;
  --ink-soft: #4A4138;
  --ink-muted: #7A6F62;
  --ecru: #EBE4D6;
  --cream: #F6F1E6;
  --paper: #FBF8F1;
  --caramel: #A86B3D;
  --caramel-deep: #7A4A28;
  --caramel-tint: #D9B492;
  --sand: #BFA478;
  --mist-gray: #C9C0B0;
  --clay: #948876;
  --signal: #8C4A3F;
  --jade: #5E6B4D;

  /* Typography */
  --font-display: 'Songti SC', 'STSong', 'SimSun', serif;
  --font-serif: 'Times New Roman', 'Songti SC', serif;
  --font-body: -apple-system, 'Helvetica Neue', 'PingFang SC', sans-serif;
  --font-mono: 'Menlo', 'Courier New', monospace;

  /* Font Sizes */
  --fs-xs: 22rpx;
  --fs-sm: 26rpx;
  --fs-base: 30rpx;
  --fs-md: 34rpx;
  --fs-lg: 44rpx;
  --fs-xl: 56rpx;
  --fs-xxl: 80rpx;
  --fs-display: 112rpx;
  --fs-hero: 160rpx;

  /* Spacing (4px grid) */
  --sp-1: 8rpx;
  --sp-2: 16rpx;
  --sp-3: 24rpx;
  --sp-4: 32rpx;
  --sp-5: 40rpx;
  --sp-6: 48rpx;
  --sp-7: 56rpx;
  --sp-8: 64rpx;
  --sp-10: 80rpx;
  --sp-12: 96rpx;
  --sp-16: 128rpx;
  --sp-20: 160rpx;

  /* Radius */
  --radius-none: 0;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 32rpx;
  --radius-full: 999rpx;

  /* Base */
  font-family: var(--font-body);
  font-size: var(--fs-base);
  color: var(--ink);
  background-color: var(--ecru);
  line-height: 1.6;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* === Typography Presets === */
.text-hero {
  font-family: var(--font-display);
  font-size: var(--fs-hero);
  line-height: 1.0;
  letter-spacing: -4rpx;
  color: var(--ink);
  font-weight: normal;
}

.text-display {
  font-family: var(--font-display);
  font-size: var(--fs-display);
  line-height: 1.1;
  letter-spacing: -2rpx;
  color: var(--ink);
}

.text-serif-title {
  font-family: var(--font-serif);
  font-size: var(--fs-xxl);
  line-height: 1.2;
  color: var(--ink);
}

.text-section-title {
  font-family: var(--font-serif);
  font-size: var(--fs-lg);
  line-height: 1.3;
  color: var(--ink);
}

.text-body {
  font-family: var(--font-body);
  font-size: var(--fs-base);
  line-height: 1.6;
  color: var(--ink);
}

.text-caption {
  font-family: var(--font-body);
  font-size: var(--fs-sm);
  line-height: 1.5;
  color: var(--ink-soft);
}

.text-kicker {
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 500;
}

.text-mono {
  font-family: var(--font-mono);
  font-size: var(--fs-xs);
  letter-spacing: 2rpx;
  color: var(--ink-muted);
}

.text-quote {
  font-family: var(--font-serif);
  font-size: var(--fs-md);
  font-style: italic;
  color: var(--ink-soft);
}

/* === Hairline === */
.hairline {
  height: 1rpx;
  background-color: var(--mist-gray);
}

.hairline-v {
  width: 1rpx;
  background-color: var(--mist-gray);
}

/* === Utility Classes === */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.text-center { text-align: center; }

/* === Safe Area Helpers === */
.safe-bottom { padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }
.overflow-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* === Grain Texture (CSS simulation) === */
.grain-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.04;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.5'/%3E%3C/svg%3E");
}

/* === Animations === */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.anim-fade-in-up {
  animation: fadeInUp 480ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.anim-fade-in {
  animation: fadeIn 260ms ease forwards;
}

/* Stagger delays */
.delay-1 { animation-delay: 60ms; }
.delay-2 { animation-delay: 120ms; }
.delay-3 { animation-delay: 180ms; }
.delay-4 { animation-delay: 240ms; }
