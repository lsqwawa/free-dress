<!-- 设置页 · PREFERENCES -->
<view class="settings-page">
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-arrow">←</text>
      <text class="text-kicker back-label">BACK</text>
    </view>
    <text class="text-mono">PREFERENCES</text>
  </view>

  <scroll-view scroll-y class="scroll-wrap">
    <view class="title-block">
      <text class="text-kicker title-kicker">PREFERENCES</text>
      <text class="text-serif-title title-main">设置</text>
      <view class="title-divider"></view>
    </view>

    <view class="section-header">
      <text class="text-kicker section-kicker">ACCOUNT</text>
      <text class="text-serif-title section-title">账号安全</text>
    </view>

    <view class="setting-list">
      <view class="setting-item" wx:for="{{settings}}" wx:key="no" bindtap="onItemTap" data-action="{{item.action}}">
        <view class="item-left">
          <text class="text-mono item-no">{{item.no}}</text>
          <text class="item-icon {{item.danger ? 'item-icon-danger' : ''}}">{{item.icon}}</text>
          <view class="item-text">
            <text class="item-title {{item.danger ? 'item-title-danger' : ''}}">{{item.title}}</text>
            <text wx:if="{{item.subtitle}}" class="text-kicker item-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
        <text class="item-arrow">›</text>
      </view>
    </view>
  </scroll-view>
</view>
