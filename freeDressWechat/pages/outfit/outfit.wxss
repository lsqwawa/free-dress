.outfit-page { min-height: 100vh; background-color: var(--ecru); overflow-x: hidden; }
.screen-header { padding: 180rpx var(--sp-6) var(--sp-4); }
.header-top { display: flex; flex-direction: row; align-items: center; justify-content: space-between; margin-bottom: var(--sp-2);}
.header-issue { color: var(--sand); font-size: 20rpx; }
.header-title { font-size: 56rpx; display: block; margin-bottom: var(--sp-3); }
.scroll-content { height: calc(100vh - 260rpx); padding: 0 var(--sp-5); padding-bottom: 160rpx; overflow-x: hidden; box-sizing: border-box; }
.section { margin-top: var(--sp-6); }

/* 宣言条 */
.manifesto { display: flex; flex-direction: row; background-color: var(--ink); padding: var(--sp-4); gap: var(--sp-3); }
.manifesto-bar { width: 4rpx; background-color: var(--caramel); }
.manifesto-body { flex: 1; }
.manifesto-kicker { color: var(--sand); display: block; margin-bottom: var(--sp-2); }
.manifesto-quote { color: var(--cream); }

/* 已选衣物 */
.thumbs-scroll { margin-top: var(--sp-5); }
.thumbs-row { display: inline-flex; flex-direction: row; gap: var(--sp-3); align-items: center; padding-right: var(--sp-6); }
.add-thumb { width: 144rpx; height: 144rpx; border-radius: var(--radius-full); border: 2rpx dashed var(--ink); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx; }
.add-thumb-icon { font-size: var(--fs-xl); color: var(--ink); }
.add-thumb-label { font-size: 16rpx; letter-spacing: 3rpx; }
.thumb-item { width: 144rpx; height: 144rpx; border-radius: var(--radius-full); overflow: hidden; position: relative; }
.thumb-img { width: 100%; height: 100%; }
.thumb-remove { position: absolute; top: 4rpx; right: 4rpx; width: 36rpx; height: 36rpx; border-radius: 50%; background-color: var(--signal); display: flex; align-items: center; justify-content: center; }
.thumb-x { font-size: 20rpx; color: var(--cream); }
.empty-hint { padding: 0 var(--sp-3); display: flex; align-items: center; }
.hint-text { font-style: italic; }

/* 风格标签 */
.tag-wrap { display: flex; flex-wrap: wrap; gap: var(--sp-2); margin-top: var(--sp-5); }
.style-tag { padding: var(--sp-2) var(--sp-4); border: 1rpx solid var(--ink); border-radius: var(--radius-full); }
.style-tag--active { background-color: var(--ink); }
.style-tag--active .style-tag-text { color: var(--cream); }
.style-tag-text { font-size: var(--fs-sm); color: var(--ink); }

/* 按钮 */
.action-bar { margin-top: var(--sp-6); }
.btn-primary { display: flex; flex-direction: row; align-items: center; justify-content: center; width: 100%; height: 96rpx; background-color: var(--caramel); border: none; gap: var(--sp-3); white-space: nowrap; border-radius: var(--radius-sm); }
.btn-primary::after { border: none; }
.btn-primary:active { background-color: var(--caramel-deep); }
.btn-text { font-size: var(--fs-base); color: var(--cream); font-weight: 500; white-space: nowrap; }
.action-dot { width: 36rpx; height: 36rpx; border-radius: 50%; background-color: var(--cream); display: flex; align-items: center; justify-content: center; }
.action-dot-inner { width: 16rpx; height: 16rpx; border-radius: 50%; background-color: var(--caramel); }
.action-hint { display: block; text-align: center; font-style: italic; margin-top: var(--sp-3); }

/* 结果 */
.result-card { margin-top: var(--sp-5); background-color: var(--cream); border: 1rpx solid var(--mist-gray); }
.result-image { aspect-ratio: 3/4; background-color: var(--ink); overflow: hidden; position: relative; }
.result-empty { display: flex; align-items: center; justify-content: center; }
.result-stripe { position: absolute; top: 40%; left: -10%; right: -10%; height: 120rpx; background-color: var(--caramel); opacity: 0.18; transform: rotate(-6deg); }
.result-stamp-top { position: absolute; top: var(--sp-3); left: var(--sp-3); right: var(--sp-3); display: flex; justify-content: space-between; }
.result-center { display: flex; flex-direction: column; align-items: center; gap: var(--sp-3); z-index: 1; }
.result-center-icon { font-size: 72rpx; color: var(--cream); }
.result-placeholder { color: var(--cream); opacity: 0.6; }
.result-grid { display: flex; flex-wrap: wrap; width: 100%; height: 100%; }
.result-grid-img { width: 50%; height: 50%; }
.result-info { padding: var(--sp-5); }
.result-caption { display: block; margin-top: var(--sp-3); }
.result-actions { display: flex; flex-direction: row; align-items: center; margin-top: var(--sp-3); padding-top: var(--sp-3); border-top: 1rpx solid var(--mist-gray); }
.action-link { flex: 1; text-align: center; padding: var(--sp-2) 0; font-size: var(--fs-sm); color: var(--ink); }
.action-divider { width: 1rpx; height: 32rpx; background-color: var(--mist-gray); }

/* 选择器弹窗 */
.picker-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(31,27,22,0.5); z-index: 1000; display: none; justify-content: flex-end; flex-direction: column; }
.picker-mask--show { display: flex; }
.picker-sheet { background-color: var(--ecru); border-radius: var(--radius-lg) var(--radius-lg) 0 0; max-height: 80vh; padding-bottom: var(--sp-4); }
.picker-header { display: flex; flex-direction: row; justify-content: space-between; align-items: center; padding: var(--sp-4) var(--sp-5); border-bottom: 1rpx solid var(--mist-gray); }
.picker-actions { display: flex; flex-direction: row; gap: var(--sp-3); align-items: center; }
.picker-clear { font-size: var(--fs-sm); color: var(--signal); }
.picker-close { font-size: var(--fs-lg); color: var(--ink); }
.picker-hint { display: block; padding: var(--sp-2) var(--sp-5); }
.picker-scroll { height: 50vh; }
.picker-grid { display: flex; flex-wrap: wrap; gap: var(--sp-2); padding: var(--sp-3) var(--sp-4); }
.picker-item { width: calc(33.33% - var(--sp-2)); aspect-ratio: 3/4; border-radius: var(--radius-sm); overflow: hidden; border: 4rpx solid transparent; position: relative; }
.picker-item--selected { border-color: var(--caramel); }
.picker-img { width: 100%; height: 100%; }
.picker-check { position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; border-radius: 50%; background-color: var(--caramel); display: flex; align-items: center; justify-content: center; }
.check-icon { font-size: 24rpx; color: var(--cream); }
.picker-done { margin: var(--sp-4); }

/* AI 推荐 */
.rec-hint { display: block; margin-top: var(--sp-2); font-style: italic; color: var(--ink-soft); }
.rec-btn { margin-top: var(--sp-3); }
.btn-outline { display: flex; flex-direction: row; align-items: center; justify-content: center; width: 100%; height: 88rpx; background-color: transparent; border: 2rpx solid var(--ink); }
.btn-outline::after { border: none; }
.btn-outline:active { background-color: var(--cream); }
.btn-outline-text { font-size: var(--fs-sm); color: var(--ink); font-weight: 500; letter-spacing: 2rpx; }
.rec-list { margin-top: var(--sp-3); display: flex; flex-direction: column; gap: var(--sp-3); }
.rec-card { background-color: var(--cream); border: 1rpx solid var(--mist-gray); padding: var(--sp-3); display: flex; flex-direction: column; gap: var(--sp-2); }
.rec-card-header { display: flex; flex-direction: row; justify-content: space-between; align-items: center; }
.rec-no { color: var(--ink-muted); font-size: var(--fs-xs); }
.rec-score-badge { background-color: var(--caramel); padding: 2rpx var(--sp-2); border-radius: var(--radius-sm); }
.rec-score-text { color: var(--cream); font-size: var(--fs-xs); }
.rec-style { font-size: var(--fs-md); font-family: var(--font-serif); color: var(--ink); }
.rec-reason { color: var(--ink-soft); display: block; }
.rec-footer { display: flex; flex-direction: row; justify-content: space-between; align-items: center; margin-top: var(--sp-1); padding-top: var(--sp-2); border-top: 1rpx solid var(--mist-gray); }
.rec-occasion { color: var(--clay); }
.rec-adopt { color: var(--caramel); font-weight: 500; }
