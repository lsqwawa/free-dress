.security-page {
  min-height: 100vh;
  padding: 88rpx var(--sp-6) var(--sp-6);
  background-color: var(--ecru);
}

.header {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--sp-7);
}

.title {
  margin-top: var(--sp-2);
  color: var(--ink);
}

.section {
  background-color: var(--cream);
  border-radius: 12rpx;
  padding: 0 var(--sp-4);
}

.item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-4) 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: var(--fs-md);
  color: var(--ink);
}

.item-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-value {
  font-size: var(--fs-sm);
  color: var(--ink-muted);
}

.item-action {
  font-size: var(--fs-sm);
  color: var(--ink);
}

.item-link {
  font-size: var(--fs-sm);
  color: #c0392b;
  margin-left: var(--sp-2);
}

.item-arrow {
  color: var(--ink-muted);
  font-size: var(--fs-md);
  margin-left: 4rpx;
}

.tips {
  margin-top: var(--sp-5);
}

.tips-text {
  color: var(--ink-muted);
  line-height: 1.6;
}
