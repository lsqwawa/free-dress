<!-- 找回密码页 · PASSWORD RECOVERY -->
<view class="forgot-page grain-bg">
  <!-- 顶部 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-arrow">←</text>
      <text class="text-kicker back-label">BACK</text>
    </view>
    <text class="text-mono">RESET</text>
  </view>

  <scroll-view scroll-y class="scroll-wrap">
    <!-- 标题 -->
    <view class="title-block anim-fade-in-up">
      <text class="text-kicker title-kicker">PASSWORD RECOVERY</text>
      <text class="text-serif-title title-main">找回密码</text>
      <view class="title-divider"></view>
      <text class="text-caption tagline">输入注册手机号和验证码 · 验证身份</text>
    </view>

    <!-- 表单 -->
    <view class="form anim-fade-in-up delay-1">
      <view class="input-group">
        <text class="input-label text-caption">注册手机号</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="input-placeholder" value="{{phone}}" bindinput="onInput" data-field="phone" />
        <view class="input-line"></view>
      </view>

      <view class="input-group">
        <text class="input-label text-caption">VERIFICATION · 验证码</text>
        <view class="captcha-row">
          <view class="captcha-input-wrap flex-1">
            <input class="input-field" maxlength="4" placeholder="请输入图中字符" placeholder-class="input-placeholder" value="{{captchaAnswer}}" bindinput="onInput" data-field="captchaAnswer" />
            <view class="input-line"></view>
          </view>
          <view class="captcha-image-wrap" bindtap="refreshCaptcha">
            <view class="captcha-placeholder" wx:if="{{captchaLoading || !captchaSvg}}">
              <text class="captcha-placeholder-text">{{captchaLoading ? '加载中' : '点击加载'}}</text>
            </view>
            <view class="captcha-image" wx:else>
              <rich-text nodes="{{captchaSvg}}"></rich-text>
            </view>
            <text class="captcha-tip text-caption">点击刷新</text>
          </view>
        </view>
      </view>
    </view>

    <view class="submit-wrap anim-fade-in-up delay-2">
      <button class="btn-primary" bindtap="handleSubmit" loading="{{loading}}">
        <text class="btn-text">验证身份</text>
        <text class="btn-arrow">→</text>
      </button>
    </view>
  </scroll-view>
</view>
