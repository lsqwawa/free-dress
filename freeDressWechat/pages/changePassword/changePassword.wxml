<!-- 修改密码页 · SECURITY -->
<view class="change-page grain-bg">
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-arrow">←</text>
      <text class="text-kicker back-label">BACK</text>
    </view>
    <text class="text-mono">SECURITY</text>
  </view>

  <scroll-view scroll-y class="scroll-wrap">
    <view class="title-block anim-fade-in-up">
      <text class="text-kicker title-kicker">SECURITY</text>
      <text class="text-serif-title title-main">修改密码</text>
      <view class="title-divider"></view>
      <text class="text-caption tagline">定期更换密码 · 守护账户安全</text>
    </view>

    <view class="form anim-fade-in-up delay-1">
      <view class="input-group">
        <text class="input-label text-caption">当前密码</text>
        <input class="input-field" password="{{true}}" maxlength="20" placeholder="请输入当前密码" placeholder-class="input-placeholder" value="{{oldPassword}}" bindinput="onInput" data-field="oldPassword" />
        <view class="input-line"></view>
      </view>

      <view class="input-group">
        <text class="input-label text-caption">新密码</text>
        <input class="input-field" password="{{true}}" maxlength="20" placeholder="6-20 位" placeholder-class="input-placeholder" value="{{newPassword}}" bindinput="onInput" data-field="newPassword" />
        <view class="input-line"></view>
      </view>

      <view class="input-group">
        <text class="input-label text-caption">确认新密码</text>
        <input class="input-field" password="{{true}}" maxlength="20" placeholder="再次输入新密码" placeholder-class="input-placeholder" value="{{confirmPassword}}" bindinput="onInput" data-field="confirmPassword" />
        <view class="input-line"></view>
      </view>
    </view>

    <view class="submit-wrap anim-fade-in-up delay-2">
      <button class="btn-primary" bindtap="handleSubmit" loading="{{loading}}">
        <text class="btn-text">确认修改</text>
        <text class="btn-arrow">✓</text>
      </button>
    </view>
  </scroll-view>
</view>
