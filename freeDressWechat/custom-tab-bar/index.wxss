.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #1F1B16;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-topline {
  height: 1rpx;
  background-color: #F6F1E6;
  opacity: 0.12;
}

.tab-indicator {
  position: absolute;
  top: 0;
  height: 4rpx;
  background-color: #A86B3D;
  border-radius: 0 0 4rpx 4rpx;
  transition: left 480ms cubic-bezier(0.22, 1, 0.36, 1);
}

.tab-items {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 110rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.tab-item--center {
  margin-top: -40rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: #7A6F62;
  font-family: -apple-system, 'Helvetica Neue', sans-serif;
  font-weight: 500;
}

.tab-label--active {
  color: #F6F1E6;
}

.tab-center-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #A86B3D;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(168, 107, 61, 0.4);
  transition: transform 180ms cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-center-btn:active {
  transform: scale(0.92) rotate(180deg);
}

.tab-icon-center {
  width: 48rpx;
  height: 48rpx;
}
