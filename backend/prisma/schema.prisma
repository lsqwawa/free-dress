// 畅搭（FreeDress）数据库模型定义
// 使用 PostgreSQL 16.13

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id            String         @id @default(uuid())

  // 手机号体系（可空：纯微信注册的账号没有手机号）
  phone         String?        @unique
  password      String?

  // 微信体系（一期主键识别用 OpenID 兜底，UnionId 二期接入）
  wechatUnionId   String?      @unique
  wechatOpenIdApp String?      @unique
  wechatOpenIdMp  String?      @unique
  wechatNickname  String?
  wechatAvatarUrl String?

  nickname      String         @default("用户")
  avatarUrl     String?
  role          UserRole       @default(USER)

  // 注册来源（埋点 / 风控）
  registerSource RegisterSource @default(PHONE)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // 关联关系
  clothes       Cloth[]
  outfits       Outfit[]
  favorites     Favorite[]
  tryOnResults  TryOnResult[]
  
  @@map("users")
}

// 用户角色枚举
enum UserRole {
  USER  // 普通用户
  VIP   // VIP用户
}

// 注册来源枚举
enum RegisterSource {
  PHONE       // 手机号注册
  WECHAT_APP  // App 端微信登录建号
  WECHAT_MP   // 小程序端微信登录建号
}

// 微信绑定/解绑审计日志
model WechatBindLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // BIND_WECHAT_MP | BIND_WECHAT_APP | UNBIND_WECHAT | BIND_PHONE | AUTO_BIND_WECHAT_MP
  platform  String   // APP | MP
  detail    String?  // JSON 字符串：记录 openid/unionid 等
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("wechat_bind_logs")
}

// 会员订阅模型
model Subscription {
  id        String           @id @default(uuid())
  userId    String
  plan      SubscriptionPlan
  startDate DateTime         @default(now())
  endDate   DateTime
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([endDate])
  @@map("subscriptions")
}

enum SubscriptionPlan {
  MONTHLY   // 月卡 19.9元
  YEARLY    // 年卡 168元
}

enum SubscriptionStatus {
  ACTIVE    // 有效
  EXPIRED   // 过期
  CANCELLED // 已取消
}

// 衣物模型
model Cloth {
  id        String        @id @default(uuid())
  userId    String
  imageUrl  String        // 图片URL
  category  ClothCategory // 衣物分类
  color     String?       // 颜色
  style     String?       // 风格
  season    String[]      // 适用季节
  tags      String[]      // 标签
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  
  // 关联关系
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitClothes OutfitCloth[]
  
  @@index([userId])
  @@index([category])
  @@map("clothes")
}

// 衣物分类枚举
enum ClothCategory {
  TOP       // 上衣
  BOTTOM    // 下装
  COAT      // 外套
  ACCESSORY // 配饰
  SHOE      // 鞋子
}

// 搭配模型
model Outfit {
  id            String         @id @default(uuid())
  userId        String
  aiDescription String?        // AI生成的搭配描述
  style         String?        // 风格
  occasion      String?        // 适用场合
  imageUrl      String?        // 搭配效果图URL
  createdAt     DateTime       @default(now())
  
  // 关联关系
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitClothes OutfitCloth[]
  favorites     Favorite[]
  tryOnResults  TryOnResult[]
  
  @@index([userId])
  @@map("outfits")
}

// 搭配-衣物关联表（多对多关系）
model OutfitCloth {
  outfitId  String
  clothId   String
  order     Int      @default(0) // 搭配中的顺序
  
  outfit    Outfit   @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  cloth     Cloth    @relation(fields: [clothId], references: [id], onDelete: Cascade)
  
  @@id([outfitId, clothId])
  @@map("outfit_clothes")
}

// 收藏模型（用户收藏的搭配）
model Favorite {
  userId    String
  outfitId  String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit    Outfit   @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  
  @@id([userId, outfitId])
  @@map("favorites")
}

// AI试穿结果模型
model TryOnResult {
  id              String        @id @default(uuid())
  userId          String
  outfitId        String
  personImageUrl  String        // 人物照片URL
  resultImageUrl  String?       // AI生成结果URL
  status          TryOnStatus   @default(PENDING)
  progress        Int           @default(0)     // 处理进度 0-100
  failReason      String?       // 失败原因
  processingTime  Int?          // 处理耗时(ms)
  createdAt       DateTime      @default(now())
  
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit          Outfit        @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([outfitId])
  @@map("tryon_results")
}

// AI试穿状态枚举
enum TryOnStatus {
  PENDING     // 排队中
  PROCESSING  // 处理中
  COMPLETED   // 已完成
  FAILED      // 失败
}

// 密码重置令牌模型
model ResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([token])
  @@index([expiresAt])
  @@map("reset_tokens")
}

// AI配额记录模型（费用控制）
model AiQuota {
  id        String   @id @default(uuid())
  userId    String
  type      String   // tryon | recommend
  date      String   // YYYY-MM-DD
  count     Int      @default(0)
  createdAt DateTime @default(now())
  
  @@unique([userId, type, date])
  @@index([userId])
  @@map("ai_quotas")
}
